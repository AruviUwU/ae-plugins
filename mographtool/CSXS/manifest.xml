<ExtensionManifest Version="7.0" ExtensionBundleId="com.mograph.tools" ExtensionBundleVersion="1.0.0" ExtensionBundleName="MoGraph Tools">
    <ExtensionList>
        <Extension Id="com.mograph.tools.panel"/>
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="[14.0, 99.9]"/>
        </HostList>
        <LocaleList>
            <Locale Code="All"/>
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.mograph.tools.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>index.html</MainPath>
                    <ScriptPath>main.js</ScriptPath>
                    <CEFCommandLine/>
                </Resources>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Mograph Tools</Menu>
                    <Geometry>
                        <Size>
                            <Height>400</Height>
                            <Width>300</Width>
                        </Size>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>